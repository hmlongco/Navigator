a value or values to navigation receivers throughout the application."}]},"doc://NavigatorUI/documentation/NavigatorUI/NavigationSending":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NavigationSending","kind":"identifier"}],"url":"\/documentation\/navigatorui\/navigationsending","identifier":"doc:\/\/NavigatorUI\/documentation\/NavigatorUI\/NavigationSending","title":"NavigationSending","navigatorTitle":[{"text":"NavigationSending","kind":"identifier"}],"kind":"symbol","role":"symbol","type":"topic","abstract":[{"type":"text","text":"A type that can broadcast hashable values through the navigation system."}]},"doc://NavigatorUI/documentation/NavigatorUI":{"kind":"symbol","type":"topic","title":"NavigatorUI","abstract":[{"text":"Managed NavigationStacks for SwiftUI.","type":"text"}],"url":"\/documentation\/navigatorui","role":"collection","identifier":"doc:\/\/NavigatorUI\/documentation\/NavigatorUI"},"doc://NavigatorUI/documentation/NavigatorUI/NavigationReceiveResumeType":{"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NavigationReceiveResumeType","kind":"identifier"}],"url":"\/documentation\/navigatorui\/navigationreceiveresumetype","identifier":"doc:\/\/NavigatorUI\/documentation\/NavigatorUI\/NavigationReceiveResumeType","title":"NavigationReceiveResumeType","navigatorTitle":[{"text":"NavigationReceiveResumeType","kind":"identifier"}],"kind":"symbol","role":"symbol","abstract":[],"type":"topic"}}}