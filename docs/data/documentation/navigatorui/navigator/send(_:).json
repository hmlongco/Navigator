ype":"text"},{"text":"the request, nor does the value need to be of type ","type":"text"},{"identifier":"doc:\/\/NavigatorUI\/documentation\/NavigatorUI\/NavigationDestination","type":"reference","isActive":true},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"They just need to be ","type":"text"},{"code":"Hashable","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"level":3,"type":"heading","text":"Sending Values","anchor":"Sending-Values"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following code broadcasts a list of actions to be handled somewhere in the application. First it selects the Home tab,"},{"type":"text","text":" "},{"type":"text","text":"then navigates to Page 2."}]},{"type":"codeListing","syntax":"swift","code":["Button(\"Go To Tab Home, Page 2\") {","    navigator.send(","        RootTabs.home,","        HomeDestinations.page2","    )","}"]},{"type":"heading","text":"Receiving Values","anchor":"Receiving-Values","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Receiving values is simple. Just register a receive handler for the desired type."}]},{"type":"codeListing","code":[".onNavigationReceive { (tab: RootTabs) in","    if tab == selectedTab {","        return .immediately","    }","    selectedTab = tab","    return .auto","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"And then perform whatever action is needed on receipt."}]},{"type":"paragraph","inlineContent":[{"text":"Here’s the handler for ","type":"text"},{"code":"HomeDestinations","type":"codeVoice"},{"type":"text","text":".`"}]},{"syntax":"swift","type":"codeListing","code":[".onNavigationReceive { (destination: HomeDestinations, navigator) in","    navigator.navigate(to: destination)","    return .auto","}"]},{"type":"paragraph","inlineContent":[{"text":"Speaking of which, receive handlers return a value of type ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/NavigatorUI\/documentation\/NavigatorUI\/NavigationReceiveResumeType"},{"text":", which tells Navigator how to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"process the remaining values in the queue. Additional values can be paused, cancelled, or simply processed normally."}]},{"inlineContent":[{"text":"Note that there should be one and only one registered handler for a given type in the navigation tree. If more than","type":"text"},{"type":"text","text":" "},{"type":"text","text":"one exists the first handler will consume the value and the remaining handlers should be ignored."}],"type":"paragraph"}],"kind":"content"}],"identifier":{"url":"doc:\/\/NavigatorUI\/documentation\/NavigatorUI\/Navigator\/send(_:)","interfaceLanguage":"swift"},"sections":[],"abstract":[{"text":"Sends a value or values to navigation receivers throughout the application.","type":"text"}],"references":{"doc://NavigatorUI/documentation/NavigatorUI":{"type":"topic","role":"collection","abstract":[{"type":"text","text":"Managed NavigationStacks for SwiftUI."}],"title":"NavigatorUI","kind":"symbol","identifier":"doc:\/\/NavigatorUI\/documentation\/NavigatorUI","url":"\/documentation\/navigatorui"},"doc://NavigatorUI/documentation/NavigatorUI/Navigator":{"kind":"symbol","role":"symbol","url":"\/documentation\/navigatorui\/navigator","abstract":[{"text":"Every ManagedNavigationStack has a Navigator to manage it.","type":"text"}],"title":"Navigator","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Navigator"}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Navigator"}],"identifier":"doc:\/\/NavigatorUI\/documentation\/NavigatorUI\/Navigator"},"doc://NavigatorUI/documentation/NavigatorUI/NavigationDestination":{"kind":"symbol","url":"\/documentation\/navigatorui\/navigationdestination","title":"NavigationDestination","role":"symbol","type":"topic","fragments":[{"text":"protocol","kind":"keyw