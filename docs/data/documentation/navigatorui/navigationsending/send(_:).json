{"kind":"symbol","identifier":{"url":"doc:\/\/NavigatorUI\/documentation\/NavigatorUI\/NavigationSending\/send(_:)","interfaceLanguage":"swift"},"abstract":[{"text":"Sends a value or values to navigation receivers throughout the application.","type":"text"}],"metadata":{"role":"symbol","title":"send(_:)","extendedModule":"NavigatorUI","modules":[{"name":"NavigatorUI"}],"externalID":"s:11NavigatorUI17NavigationSendingPAAE4sendyySH_pd_tF","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"send","kind":"identifier"},{"text":"(any ","kind":"text"},{"text":"Hashable","kind":"typeIdentifier","preciseIdentifier":"s:SH"},{"text":"...)","kind":"text"}],"roleHeading":"Instance Method"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/navigatorui\/navigationsending\/send(_:)"]}],"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"preciseIdentifier":"s:ScM","kind":"attribute","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"send"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"values"},{"kind":"text","text":": any "},{"preciseIdentifier":"s:SH","kind":"typeIdentifier","text":"Hashable"},{"kind":"text","text":"...)"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is the core functionality behind deep linking support in Navigator."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The primary difference between this and "},{"type":"codeVoice","code":"navigate(to:)"},{"type":"text","text":" is that you don’t need to know what navigator is handling"},{"type":"text","text":" "},{"type":"text","text":"the request, nor does the value need to be of type "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NavigatorUI\/documentation\/NavigatorUI\/NavigationDestination"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"They just need to be "},{"type":"codeVoice","code":"Hashable"},{"type":"text","text":"."}]},{"text":"Sending Values","type":"heading","level":3,"anchor":"Sending-Values"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following code broadcasts a list of actions to be handled somewhere in the application. First it selects the Home tab,"},{"type":"text","text":" "},{"type":"text","text":"then navigates to Page 2."}]},{"syntax":"swift","code":["Button(\"Go To Tab Home, Page 2\") {","    navigator.send(","        RootTabs.home,","        HomeDestinations.page2","    )","}"],"type":"codeListing"},{"text":"Receiving Values","type":"heading","level":3,"anchor":"Receiving-Values"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Receiving values is simple. Just register a receive handler for the desired type."}]},{"syntax":"swift","code":[".onNavigationReceive { (tab: RootTabs) in","    if tab == selectedTab {","        return .immediately","    }","    selectedTab = tab","    return .auto","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"And then perform whatever action is needed on receipt."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Here’s the handler for "},{"type":"codeVoice","code":"HomeDestinations"},{"type":"text","text":".`"}]},{"syntax":"swift","code":[".onNavigationReceive { (destination: HomeDestinations, navigator) in","    navigator.navigate(to: destination)","    return .auto","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Speaking of which, receive handlers return a value of type "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NavigatorUI\/documentation\/NavigatorUI\/NavigationReceiveResumeType"},{"type":"text","text":", which tells Navigator how to"},{"type":"text","text":" "},{"type":"text","text":"process the remaining values in the queue. Additional values can be paused, cancelled, or simply processed normally."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that there should be one and only one registered handler for a given type in the navigation tree. If more than"},{"type":"text","text":" "},{"type":"text","text":"one exists the first handler will consume the value and the remaining handlers should be ignored."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/NavigatorUI\/documentation\/NavigatorUI","doc:\/\/NavigatorUI\/documentation\/NavigatorUI\/NavigationSending"]]},"references":{"doc://NavigatorUI/documentation/NavigatorUI/NavigationSending/send(_:)":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"send","kind":"identifier"},{"text":"(any ","kind":"text"},{"text":"Hashable","preciseIdentifier":"s:SH","kind":"typeIdentifier"},{"text":"...)","kind":"text"}],"kind":"symbol","type":"topic","title":"send(_:)","identifier":"doc:\/\/NavigatorUI\/documentation\/NavigatorUI\/NavigationSending\/send(_:)","url":"\/documentation\/navigatorui\/navigationsending\/send(_:)","abstract":[{"type":"text","text":"Sends a value or values to navigation receivers throughout the application."}],"role":"symbol"},"doc://NavigatorUI/documentation/NavigatorUI/NavigationSending":{"title":"NavigationSending","type":"topic","abstract":[{"type":"text","text":"A type that can broadcast hashable values through the navigation system."}],"kind":"symbol","navigatorTitle":[{"text":"NavigationSending","kind":"identifier"}],"role":"symbol","url":"\/documentation\/navigatorui\/navigationsending","identifier":"doc:\/\/NavigatorUI\/documentation\/NavigatorUI\/NavigationSending","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},